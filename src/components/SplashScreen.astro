---
// SplashScreen.astro
// Cinematic intro animation
---
<div id="splash-screen" class="splash-container" role="dialog" aria-modal="true" aria-label="Introduction">
  <div class="splash-content">
    <h1 class="splash-brand">Marvelous journal of a wanderer</h1>
    <div class="splash-subtitle">Street Photography</div>
  </div>
  <button id="splash-skip" class="splash-skip" aria-label="Passer l'introduction">Passer →</button>
</div>

<style>
  .splash-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #050505;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.8s cubic-bezier(0.77, 0, 0.175, 1), opacity 0.5s ease; 
  }

  /* Hidden state: we push it out of view AND make it transparent */
  .splash-container.is-hidden {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .splash-content {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    animation: revealText 2s ease-in-out forwards;
  }

  .splash-brand {
    font-family: 'Bodoni Moda', serif;
    font-size: clamp(2rem, 8vw, 4.5rem);
    font-weight: 500;
    font-style: italic;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .splash-subtitle {
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.7rem;
    color: #666;
    margin-top: 1rem;
  }

  .splash-skip {
    position: absolute;
    bottom: 2.5rem;
    right: 2.5rem;
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.5);
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    cursor: pointer;
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.4s ease, color 0.3s ease, border-color 0.3s ease;
    /* pointer-events handled by JS — the button remains keyboard-focusable */
  }
  .splash-skip.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
  .splash-skip:hover {
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.5);
  }
  .splash-skip:focus-visible {
    outline: 2px solid rgba(255,255,255,0.8);
    outline-offset: 4px;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .splash-content {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
    .splash-container {
      transition: none !important;
    }
  }

  @keyframes revealText {
    0% { opacity: 0; transform: translateY(20px); filter: blur(10px); }
    30% { opacity: 1; transform: translateY(0); filter: blur(0px); }
    70% { opacity: 1; transform: translateY(0); filter: blur(0px); }
    100% { opacity: 0; transform: translateY(-20px); filter: blur(5px); }
  }
</style>

<script>
  let splashTimer: ReturnType<typeof setTimeout> | null = null;
  let hideTimer: ReturnType<typeof setTimeout> | null = null;

  function initSplash() {
    const splash = document.getElementById('splash-screen');
    const skipBtn = document.getElementById('splash-skip') as HTMLButtonElement | null;
    if (!splash) return;

    if (sessionStorage.getItem('splashSeen')) {
      splash.style.display = 'none';
      splash.classList.add('is-hidden');
      window.dispatchEvent(new Event('splashFinished'));
      return;
    }

    if (splashTimer) clearTimeout(splashTimer);
    if (hideTimer) clearTimeout(hideTimer);

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const dismiss = () => {
      if (splashTimer) clearTimeout(splashTimer);
      if (hideTimer) clearTimeout(hideTimer);
      splash.classList.add('is-hidden');
      sessionStorage.setItem('splashSeen', 'true');
      splash.removeEventListener('keydown', trapFocus);
      window.dispatchEvent(new Event('splashFinished'));
      hideTimer = setTimeout(() => {
        splash.style.display = 'none';
        splash.setAttribute('aria-hidden', 'true');
      }, 800);
    };

    // Trap Tab focus inside the splash so keyboard users can't tab into
    // the hidden page content while the splash is up.
    const trapFocus = (e: KeyboardEvent) => {
      if (e.key !== 'Tab' || !skipBtn) return;
      e.preventDefault();
      skipBtn.focus();
    };

    // Reduced motion: immediate dismiss, no animation
    if (prefersReducedMotion) {
      dismiss();
      return;
    }

    // Focus the skip button immediately so keyboard users can dismiss
    // even before the fade-in finishes.
    splash.addEventListener('keydown', trapFocus);
    skipBtn?.focus({ preventScroll: true });

    // Reveal the skip button after 800ms (visual fade only — it is
    // already focusable/focused for keyboard users).
    splashTimer = setTimeout(() => {
      skipBtn?.classList.add('is-visible');
    }, 800);

    // Auto-dismiss after 2200ms
    hideTimer = setTimeout(dismiss, 2200);

    // Keyboard: the button is always focusable, Enter/Space dismiss immediately
    skipBtn?.addEventListener('click', dismiss);
    skipBtn?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        dismiss();
      }
    });
  }

  // Cleanup if we navigate DURING the splash (unlikely but possible)
  document.addEventListener('astro:before-preparation', () => {
    if (splashTimer) clearTimeout(splashTimer);
    if (hideTimer) clearTimeout(hideTimer);
  });

  document.addEventListener('astro:page-load', initSplash);
</script>
