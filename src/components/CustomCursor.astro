---
// CustomCursor.astro
// Un curseur personnalisé pour le mode Desktop
---
<div class="cursor-dot" id="custom-cursor" transition:persist="custom-cursor"></div>

<style>
  @media (pointer: fine) {
    :global(body) {
      cursor: none !important;
    }
    
    :global(a), :global(button), :global(.has-overlay), :global(.clickable-image) {
      cursor: none !important;
    }
    
    .cursor-dot {
      position: fixed;
      top: 0;
      left: 0;
      width: 8px;
      height: 8px;
      background-color: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 20000;
      /* On retire le translate(-50%, -50%) d'ici pour le gérer en JS proprement */
      transition: width 0.15s cubic-bezier(0.2, 0, 0.2, 1), 
                  height 0.15s cubic-bezier(0.2, 0, 0.2, 1), 
                  background-color 0.15s ease, 
                  opacity 0.2s ease;
      mix-blend-mode: difference;
      opacity: 0; 
      will-change: transform;
    }

    .cursor-dot.is-hovering {
      width: 32px;
      height: 32px;
      background-color: color-mix(in srgb, var(--accent) 15%, transparent);
      border: 1px solid var(--accent);
      mix-blend-mode: normal;
    }

    .cursor-dot.is-reading {
      width: 50px;
      height: 50px;
      background-color: color-mix(in srgb, var(--accent) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
      mix-blend-mode: normal;
      backdrop-filter: blur(2px);
    }
    
    .cursor-dot.is-reading::after {
      content: '+';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -51%);
      color: var(--accent);
      font-size: 18px;
      font-weight: 200;
    }
  }

  @media (pointer: coarse) {
    .cursor-dot {
      display: none;
    }
  }
</style>

<script>
  let cursorInitialized = false;
  let rafId: number | null = null;

  function initCursor() {
    const cursor = document.getElementById('custom-cursor');
    if (!cursor) return;

    // Si déjà initialisé globalement, on s'assure juste que l'opacité est correcte
    if (cursorInitialized) {
      cursor.style.opacity = '1';
      return;
    }

    let mouseX = -100;
    let mouseY = -100;
    let currentX = -100;
    let currentY = -100;
    let firstMove = false;

    const onPointerMove = (e: PointerEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      
      if (!firstMove) {
        currentX = mouseX;
        currentY = mouseY;
        cursor.style.opacity = '1';
        firstMove = true;
      }
    };

    const updateCursor = () => {
      if (firstMove) {
        // Lerp plus rapide (0.45) pour réduire l'impression de lag tout en gardant du lissage
        currentX += (mouseX - currentX) * 0.45;
        currentY += (mouseY - currentY) * 0.45;
        
        // Seuil pour arrêter le calcul si on est quasi immobile
        if (Math.abs(mouseX - currentX) < 0.1 && Math.abs(mouseY - currentY) < 0.1) {
          currentX = mouseX;
          currentY = mouseY;
        }

        // On utilise une seule translation 3D optimisée
        cursor.style.transform = `translate3d(calc(${currentX}px - 50%), calc(${currentY}px - 50%), 0)`;
      }
      rafId = requestAnimationFrame(updateCursor);
    };

    window.addEventListener('pointermove', onPointerMove, { passive: true });
    rafId = requestAnimationFrame(updateCursor);

    const handleOver = (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      if (!target) return;

      const isInteractive = target.closest('a, button, .clickable-image');
      const isReading = target.closest('.has-overlay');

      cursor.classList.toggle('is-hovering', !!isInteractive);
      cursor.classList.toggle('is-reading', !!isReading);
    };

    document.addEventListener('mouseover', handleOver);
    document.addEventListener('mouseleave', () => cursor.style.opacity = '0');
    document.addEventListener('mouseenter', () => cursor.style.opacity = '1');

    cursorInitialized = true;
  }

  document.addEventListener('astro:page-load', initCursor);
</script>
