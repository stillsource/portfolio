---
// Navbar.astro
import AudioPlayer from './AudioPlayer.astro';
import Search from './Search.astro';

interface Props {
  mode?: 'index' | 'roll' | 'about';
  audioUrl?: string;
}

const { mode = 'index', audioUrl } = Astro.props;
---

<div id="main-nav" class={`nav-container ${mode !== 'index' ? 'is-visible' : ''}`} transition:persist="main-nav">
  <nav class="tag-menu" aria-label="Navigation principale">
    {mode !== 'about' && (
      <>
        <a href="/" class="brand">Marvelous journal of a wanderer</a>
        <div class="separator" aria-hidden="true"></div>
        <Search />
        <div class="separator" aria-hidden="true"></div>
      </>
    )}
    
    {mode === 'index' && (
      <>
        <AudioPlayer audioUrl={audioUrl} />
        <a href="/about" class="tag-link">À propos</a>
      </>
    )}

    {mode === 'roll' && (
      <>
        <a href="/" class="tag-link">Index</a>
        <AudioPlayer audioUrl={audioUrl} />
        <a href="/about" class="tag-link">À propos</a>
      </>
    )}

    {mode === 'about' && (
      <>
        <a href="/" class="tag-link">Retour au Flux</a>
      </>
    )}

    <div class="separator" aria-hidden="true"></div>
    <button id="theme-toggle" class="theme-btn" aria-label="Passer en mode clair" aria-pressed="false">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </nav>
</div>

<style>
  .nav-container {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translate(-50%, 0);
    z-index: 100;
    display: flex;
    justify-content: center;
    width: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }
  
  .nav-container.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .tag-menu {
    background: color-mix(in srgb, var(--bg-base) 40%, rgba(20, 20, 20, 0.4));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    white-space: nowrap;
    transition: background 2s ease;
  }

  .brand {
    font-family: 'Bodoni Moda', serif;
    font-weight: 700;
    font-style: italic;
    color: var(--accent);
    text-decoration: none;
    font-size: 1.2rem;
  }

  .separator {
    width: 1px;
    height: 15px;
    background: rgba(255,255,255,0.2);
  }

  .tag-link { 
    color: var(--text-muted); 
    text-decoration: none; 
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.3s ease;
  }

  .tag-link:hover {
    color: var(--accent);
  }

  .theme-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color 0.3s ease, transform 0.3s ease;
  }
  .theme-btn:hover { color: var(--accent); transform: scale(1.1); }
  .theme-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 50%; }

  /* Show the icon matching the active theme */
  :root[data-theme="light"] .theme-btn .icon-sun { display: none; }
  :root[data-theme="dark"] .theme-btn .icon-moon { display: none; }
  :root:not([data-theme="light"]) .theme-btn .icon-moon { display: none; }

  @media (max-width: 640px) {
    .brand { display: none; }
    .separator { display: none; }
    .tag-menu { gap: 1rem; padding: 0.5rem 1rem; }
  }
</style>

<script>
  function setupNavVisibility() {
    const nav = document.getElementById('main-nav');
    if (!nav) return;

    // On the index, wait for the splash screen
    if (window.location.pathname === '/') {
      const showNav = () => nav.classList.add('is-visible');
      if (sessionStorage.getItem('splashSeen')) {
        showNav();
      } else {
        window.addEventListener('splashFinished', showNav, { once: true });
      }
    } else {
      // Otherwise show immediately (already done by the CSS class, or force it)
      nav.classList.add('is-visible');
    }
  }

  document.addEventListener('astro:page-load', setupNavVisibility);

  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const updateBtn = (theme: string) => {
      const isLight = theme === 'light';
      btn.setAttribute('aria-pressed', String(isLight));
      btn.setAttribute('aria-label', isLight ? 'Passer en mode sombre' : 'Passer en mode clair');
    };

    // Initialize the button state
    updateBtn(document.documentElement.getAttribute('data-theme') || 'dark');

    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme-preference', next);
      updateBtn(next);
    });
  }

  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
