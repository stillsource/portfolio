<div class="search-wrapper">
  <button id="search-toggle" class="search-btn" aria-label="Rechercher" aria-expanded="false" aria-controls="search-overlay">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
  </button>

  <div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Recherche" aria-labelledby="search-input-label">
    <div class="search-modal">
      <header class="search-header">
        <label id="search-input-label" for="search-input" class="sr-only">Rechercher dans le portfolio</label>
        <input type="text" id="search-input" placeholder="Rechercher un lieu, un tag, un souvenir..." autocomplete="off" />
        <button id="search-close" class="close-btn" aria-label="Fermer la recherche">&times;</button>
      </header>

      <div id="search-results" class="search-results" aria-live="polite" aria-atomic="false">
        <div class="search-placeholder">Commencez à taper pour explorer les fragments...</div>
      </div>
      <span id="search-status" class="sr-only" aria-live="polite" aria-atomic="true"></span>
    </div>
  </div>
</div>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
  }

  .search-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .search-btn:hover {
    color: var(--accent);
    transform: scale(1.1);
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 5, 5, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding: 10vh 2rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .search-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .search-modal {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1rem;
  }

  #search-input {
    flex: 1;
    background: none;
    border: none;
    font-family: 'Bodoni Moda', serif;
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-style: italic;
    color: var(--text-main);
    outline: none;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 2rem;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .close-btn:hover {
    color: var(--accent);
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
    overflow-y: auto;
    padding-bottom: 5rem;
  }

  .search-placeholder {
    grid-column: 1 / -1;
    text-align: center;
    font-family: 'Bodoni Moda', serif;
    font-style: italic;
    color: var(--text-muted);
    font-size: 1.2rem;
    padding-top: 5rem;
  }

  :global(.search-result-item) {
    animation: reveal 0.6s ease forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  :global(.search-result-link) {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.4s ease;
  }

  :global(.search-result-link:hover) {
    transform: translateY(-5px);
  }

  :global(.result-img-wrapper) {
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
  }

  :global(.result-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  :global(.search-result-link:hover .result-img) {
    transform: scale(1.05);
  }

  :global(.result-info) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  :global(.result-date) {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  :global(.result-title) {
    font-family: 'Bodoni Moda', serif;
    font-size: 1.4rem;
    font-style: italic;
    color: var(--text-main);
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  import { applyThemeColors } from '../scripts/utils/colors';
  import type { SearchIndexItem } from '../types/content';

  let searchIndex: SearchIndexItem[] = [];
  let isIndexLoaded = false;

  async function loadSearchIndex() {
    if (isIndexLoaded) return;
    try {
      searchIndex = await (await fetch('/search-index.json')).json();
      isIndexLoaded = true;
    } catch (e) {
      console.error("Search index load error:", e);
    }
  }

  function setupSearch() {
    const els = {
      toggle: document.getElementById('search-toggle'),
      overlay: document.getElementById('search-overlay'),
      close: document.getElementById('search-close'),
      input: document.getElementById('search-input') as HTMLInputElement,
      results: document.getElementById('search-results'),
      status: document.getElementById('search-status'),
    };

    if (!Object.values(els).every(Boolean)) return;

    const getFocusableEls = () =>
      Array.from(els.overlay!.querySelectorAll<HTMLElement>(
        'button, input, a[href], [tabindex="0"]'
      )).filter(el => !el.hasAttribute('disabled'));

    const trapFocus = (e: KeyboardEvent) => {
      if (e.key !== 'Tab') return;
      const focusable = getFocusableEls();
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    };

    const toggleOverlay = (open: boolean) => {
      els.overlay!.classList.toggle('is-open', open);
      (els.toggle as HTMLElement | null)?.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) {
        els.overlay!.addEventListener('keydown', trapFocus);
        loadSearchIndex().then(() => els.input!.focus());
      } else {
        els.overlay!.removeEventListener('keydown', trapFocus);
        els.input!.value = '';
        renderResults([]);
        (els.toggle as HTMLElement)?.focus();
      }
    };

    const renderResults = (results: SearchIndexItem[]) => {
      if (!els.results) return;

      if (results.length === 0) {
        const msg = els.input!.value
          ? 'Aucun fragment trouvé pour cette quête...'
          : 'Commencez à taper pour explorer les fragments...';
        const placeholder = document.createElement('div');
        placeholder.className = 'search-placeholder';
        placeholder.textContent = msg;
        els.results.replaceChildren(placeholder);
        if (els.status) els.status.textContent = els.input!.value ? 'Aucun résultat.' : '';
        return;
      }

      if (els.status) els.status.textContent = `${results.length} résultat${results.length > 1 ? 's' : ''} trouvé${results.length > 1 ? 's' : ''}.`;

      const fragment = document.createDocumentFragment();
      results.forEach((res, i) => {
        const item = document.createElement('div');
        item.className = 'search-result-item';
        item.style.animationDelay = `${i * 0.05}s`;

        const link = document.createElement('a');
        link.href = `/roll/${res.id}`;
        link.className = 'search-result-link result-trigger';
        link.dataset.palette = JSON.stringify(res.palette || []);

        const imgWrapper = document.createElement('div');
        imgWrapper.className = 'result-img-wrapper';
        const img = document.createElement('img');
        img.src = res.cover || '';
        img.alt = res.title;
        img.className = 'result-img';
        img.loading = 'lazy';
        imgWrapper.appendChild(img);

        const info = document.createElement('div');
        info.className = 'result-info';
        const date = document.createElement('span');
        date.className = 'result-date';
        date.textContent = new Date(res.date).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
        const title = document.createElement('span');
        title.className = 'result-title';
        title.textContent = res.title;
        info.appendChild(date);
        info.appendChild(title);

        link.appendChild(imgWrapper);
        link.appendChild(info);
        item.appendChild(link);
        fragment.appendChild(item);
      });
      els.results.replaceChildren(fragment);
    };

    // Navbar is transition:persist — attach listeners only once
    const resultsEl = els.results as HTMLElement & { __searchBound?: boolean };
    if (resultsEl.__searchBound) return;
    resultsEl.__searchBound = true;

    // Event delegation for the aura on search results
    els.results!.addEventListener('mouseenter', (e) => {
      const trigger = (e.target as HTMLElement).closest('.result-trigger') as HTMLElement;
      if (trigger) {
        applyThemeColors(JSON.parse(trigger.dataset.palette || '[]'), true);
      }
    }, true);

    els.results!.addEventListener('mouseleave', (e) => {
      const trigger = (e.target as HTMLElement).closest('.result-trigger') as HTMLElement;
      if (trigger) {
        applyThemeColors([], false);
      }
    }, true);

    els.toggle!.addEventListener('click', () =>
      toggleOverlay(!els.overlay!.classList.contains('is-open'))
    );
    els.close!.addEventListener('click', () => toggleOverlay(false));

    // Close when clicking the backdrop (outside the modal)
    els.overlay!.addEventListener('click', (e) => {
      if (e.target === els.overlay) toggleOverlay(false);
    });

    els.input!.addEventListener('input', () => {
      const q = els.input!.value.toLowerCase().trim();
      if (!q) return renderResults([]);

      const filtered = searchIndex.filter(item =>
        item.title.toLowerCase().includes(q) ||
        item.tags.some((t: string) => t.toLowerCase().includes(q)) ||
        (item.poem && item.poem.toLowerCase().includes(q))
      );
      renderResults(filtered.slice(0, 12));
    });

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && els.overlay!.classList.contains('is-open')) toggleOverlay(false);
    });

    // Close before any navigation (click on a result, external link, etc.)
    document.addEventListener('astro:before-preparation', () => {
      if (els.overlay!.classList.contains('is-open')) toggleOverlay(false);
    });
  }

  document.addEventListener('astro:page-load', setupSearch);
</script>
