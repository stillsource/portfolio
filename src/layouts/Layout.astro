---
import '@fontsource/inter';
import '@fontsource/bodoni-moda';
import '../styles/global.css';
import '../styles/reveal.css';
import CustomCursor from '../components/CustomCursor.astro';
import DustCanvas from '../components/DustCanvas.astro';
import LightboxGlobal from '../components/LightboxGlobal.astro';
import HeadMeta from '../components/layout/HeadMeta.astro';
import NavigationChrome from '../components/layout/NavigationChrome.astro';
import ReadProgress from '../components/layout/ReadProgress.astro';
import Analytics from '@vercel/analytics/astro';

interface PreloadImage {
  url: string;
  srcset?: string;
  sizes?: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: object;
  preloadImage?: PreloadImage;
}

const {
  title,
  description = "Marvelous journal of a wanderer - Portfolio de photographie de rue immersif et poétique.",
  ogImage = "/og-image.svg",
  ogType = "website",
  canonicalUrl,
  jsonLd,
  preloadImage,
} = Astro.props;

const canon = canonicalUrl ?? Astro.url.href;
---
<!doctype html>
<html lang="fr">
  <head>
    <HeadMeta
      title={title}
      description={description}
      canonicalUrl={canon}
      ogImage={ogImage}
      ogType={ogType}
      jsonLd={jsonLd}
      preloadImage={preloadImage}
    />
  </head>
  <body>
    <NavigationChrome />
    <CustomCursor />
    <ReadProgress />
    <DustCanvas />
    <LightboxGlobal />

    <slot />
    <Analytics />
  </body>
</html>
