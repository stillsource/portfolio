---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Roll from '../../components/Roll.astro';
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths() {
  const allRolls = await getCollection('rolls');
  const sortedRolls = allRolls.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
  return sortedRolls.map((roll, index) => {
    const nextRoll = sortedRolls[index + 1] || null;
    return {
      params: { slug: roll.id },
      props: { roll, nextRoll },
    };
  });
}

const { roll, nextRoll } = Astro.props;
const nextUrl = nextRoll ? `/roll/${nextRoll.id}` : "/about";
const nextLabel = nextRoll ? "Continuer l'errance" : "Fin du recueil";
const nextTitle = nextRoll ? nextRoll.data.title : "À Propos de l'Errance";

const nextPalette = nextRoll?.data.palette?.length
  ? nextRoll.data.palette
  : nextRoll?.data.dominantColor
    ? [nextRoll.data.dominantColor]
    : [];

const ogImage = roll.data.images?.[0]?.url ?? '/og-image.svg';
const ogDescription = roll.data.poem
  ? roll.data.poem.slice(0, 160)
  : `${roll.data.title} — fragments photographiques`;

const isProd = import.meta.env.PROD;
const firstImg = roll.data.images?.[0];
const preloadImage = firstImg
  ? isProd
    ? {
        url: `/_vercel/image?url=${encodeURIComponent(firstImg.url)}&w=800&q=80`,
        srcset: [400, 800, 1200].map(w =>
          `/_vercel/image?url=${encodeURIComponent(firstImg.url)}&w=${w}&q=80 ${w}w`,
        ).join(', '),
        sizes: '(max-width: 768px) 100vw, 66vw',
      }
    : { url: firstImg.url }
  : undefined;

const rollJsonLd = {
  "@context": "https://schema.org",
  "@type": "PhotoAlbum",
  "name": roll.data.title,
  "description": ogDescription,
  "datePublished": roll.data.date.toISOString().split('T')[0],
  "url": Astro.url.href,
  "image": roll.data.images.slice(0, 5).map(img => img.url),
  "author": {
    "@type": "Person",
    "name": "Hors-Champ"
  }
};
---

<Layout
  title={`${roll.data.title} — Hors-Champ`}
  description={ogDescription}
  ogImage={ogImage}
  ogType="article"
  jsonLd={rollJsonLd}
  preloadImage={preloadImage}
>
  <Navbar mode="roll" audioUrl={roll.data.audioUrl} />

  <main>
    <Roll
      title={roll.data.title}
      poem={roll.data.poem}
      images={roll.data.images}
      dominantColor={roll.data.dominantColor}
      palette={roll.data.palette}
      poemAnimation={roll.data.poemAnimation}
    />
    
    <footer
      class="next-roll-footer reveal-on-scroll color-trigger"
      id="next-roll-trigger"
      data-next-url={nextUrl}
      data-palette={JSON.stringify(nextPalette)}
      data-next-images={JSON.stringify(nextRoll?.data.images?.slice(0, 4).map(i => i.url) ?? [])}
    >
      <div class="next-progress-container">
        <div class="next-progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="Navigation automatique"></div>
        <button class="next-cancel-btn" id="next-cancel-btn" aria-label="Annuler la navigation automatique" hidden>×</button>
      </div>
      <span class="next-label">{nextLabel}</span>
      <a href={nextUrl} class="next-title">{nextTitle}</a>
    </footer>
  </main>

  <style is:global>
    .next-roll-footer {
      padding: 15rem 2rem 10rem;
      text-align: center;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      position: relative;
      overflow: hidden;
    }

    .next-progress-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: rgba(255, 255, 255, 0.05);
    }

    .next-progress-bar {
      height: 100%;
      width: 0%;
      background: var(--accent);
      transition: width 3.5s linear;
    }

    .next-roll-footer.is-loading .next-progress-bar {
      width: 100%;
    }

    /* Skip the transition when cancelling so the bar snaps back to 0
       instead of counting down from 100 → 0 as the "is-loading" class
       is removed. */
    .next-roll-footer.is-cancelling .next-progress-bar {
      transition: none;
      width: 0%;
    }

    .next-cancel-btn {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--text-muted);
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      line-height: 1;
      padding: 0.2rem 0.4rem;
      cursor: pointer;
      opacity: 0.5;
      transition: opacity 0.2s ease;
    }
    .next-cancel-btn:hover, .next-cancel-btn:focus-visible {
      opacity: 1;
      outline: none;
    }

    .next-label {
      font-family: 'Inter', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-size: 0.7rem;
      color: var(--text-muted);
      display: block;
      margin-bottom: 1rem;
    }

    .next-title {
      font-family: 'Bodoni Moda', serif;
      font-size: clamp(2rem, 10vw, 4rem);
      font-style: italic;
      color: var(--text-main);
      text-decoration: none;
      transition: opacity 0.3s ease;
    }

    .next-title:hover {
      opacity: 0.7;
    }
  </style>

  <script>
    import { navigate } from 'astro:transitions/client';

    const observerOptions = { root: null, rootMargin: '0px', threshold: 0.15 };
    const navOptions = { root: null, rootMargin: '0px', threshold: 0.8 };
    let navigationTimer: ReturnType<typeof setTimeout> | null = null;
    let revealObserver: IntersectionObserver | null = null;
    let navTriggerObserver: IntersectionObserver | null = null;

    // Cleanup before navigation: disconnect observers so they don't hold
    // references to detached DOM nodes (which would otherwise leak across
    // soft navigations and fire callbacks targeting the old page).
    document.addEventListener('astro:before-preparation', () => {
      if (navigationTimer) { clearTimeout(navigationTimer); navigationTimer = null; }
      document.body.classList.remove('is-transitioning');
      revealObserver?.disconnect();
      navTriggerObserver?.disconnect();
      revealObserver = null;
      navTriggerObserver = null;
    });

    const makeRevealObserver = () => new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver?.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const makeNavTriggerObserver = () => new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const footer = document.getElementById('next-roll-trigger');
        const cancelBtn = document.getElementById('next-cancel-btn') as HTMLButtonElement | null;
        const progressBar = footer?.querySelector('.next-progress-bar') as HTMLElement | null;
        if (!footer) return;

        let tickRafId: number | null = null;

        const cancelNav = () => {
          // Snap the bar back to 0 without replaying the count-up transition
          // in reverse: add `is-cancelling` (transition: none), force a reflow,
          // then drop both classes so future reveals animate normally.
          footer.classList.add('is-cancelling');
          footer.classList.remove('is-loading');
          void footer.offsetWidth;
          footer.classList.remove('is-cancelling');
          document.body.classList.remove('is-transitioning');
          if (tickRafId !== null) { cancelAnimationFrame(tickRafId); tickRafId = null; }
          if (navigationTimer) { clearTimeout(navigationTimer); navigationTimer = null; }
          if (cancelBtn) cancelBtn.hidden = true;
          if (progressBar) progressBar.setAttribute('aria-valuenow', '0');
        };

        if (entry.isIntersecting) {
          // Preload the next roll's images
          try {
            const nextImages: string[] = JSON.parse(footer.dataset.nextImages || '[]');
            nextImages.forEach(url => { new Image().src = url; });
          } catch { /* ignore */ }

          const nextUrl = footer.dataset.nextUrl;
          if (nextUrl) {
            footer.classList.add('is-loading');
            if (cancelBtn) {
              cancelBtn.hidden = false;
              cancelBtn.onclick = () => { cancelNav(); cancelBtn.hidden = true; };
            }

            // Progressive update of aria-valuenow
            const startTime = Date.now();
            const duration = 4000;
            const tick = () => {
              if (!footer.classList.contains('is-loading')) return;
              const elapsed = Date.now() - startTime;
              const pct = Math.min(100, Math.round((elapsed / duration) * 100));
              if (progressBar) progressBar.setAttribute('aria-valuenow', String(pct));
              if (pct < 100) tickRafId = requestAnimationFrame(tick);
            };
            tickRafId = requestAnimationFrame(tick);

            if (navigationTimer) clearTimeout(navigationTimer);
            navigationTimer = setTimeout(() => {
              if (footer.classList.contains('is-loading')) {
                if (cancelBtn) cancelBtn.hidden = true;
                navigate(nextUrl);
              }
            }, duration);
          }
        } else {
          // Cancel if we scroll back up
          cancelNav();
        }
      });
    }, navOptions);

    document.addEventListener('astro:page-load', () => {
      revealObserver?.disconnect();
      navTriggerObserver?.disconnect();
      revealObserver = makeRevealObserver();
      navTriggerObserver = makeNavTriggerObserver();

      const reveals = document.querySelectorAll('.reveal-on-scroll');
      reveals.forEach(el => revealObserver!.observe(el));

      const nextTitle = document.querySelector('.next-title');
      if (nextTitle) {
        navTriggerObserver.observe(nextTitle);
      }
    });
  </script>
</Layout>
