---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout
  title="Hors-Champ — À propos"
  description="L'errant derrière l'objectif — photographie de rue, poésie du quotidien et fragments d'instants suspendus."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Hors-Champ",
    "url": Astro.url.origin,
    "description": "L'errant derrière l'objectif — photographie de rue, poésie du quotidien et fragments d'instants suspendus."
  }}
>
  <Navbar mode="about" />

  <main class="about-editorial">
    <header class="masthead reveal-on-scroll">
      <span class="issue">№&nbsp;I</span>
      <span class="edition">Hors-Champ</span>
      <span class="dateline">Carnet d'errance · 2026</span>
    </header>

    <section class="hero">
      <p class="kicker reveal-on-scroll stagger-1">Manifeste</p>
      <h1 class="title reveal-on-scroll stagger-2">
        <em>L'errant</em>
        <span class="roman">derrière l'objectif</span>
      </h1>
      <p class="standfirst reveal-on-scroll stagger-3">
        Photographie de rue, poésie du quotidien et fragments d'instants suspendus.
      </p>
    </section>

    <article class="body reveal-on-scroll stagger-4">
      <figure class="byline-portrait" aria-hidden="true">
        <img
          src="/portrait.jpg"
          alt=""
          class="portrait-img"
          loading="lazy"
          onerror="this.closest('.byline-portrait').classList.add('no-image'); this.remove();"
        />
        <figcaption class="portrait-fallback">
          <span class="portrait-monogram" aria-hidden="true">HC</span>
          <span class="portrait-hint">Portrait</span>
        </figcaption>
      </figure>

      <p class="lede drop-cap">
        Photographe de rue passionné, je capture l'essence de l'instant urbain à travers l'objectif de mon Fujifilm. Ce portfolio n'est pas une simple galerie, mais un carnet de bord visuel, une collection de moments suspendus organisés par balades et par atmosphères.
      </p>
      <p>
        L'errance est ma méthode. Sans but précis, je parcours les villes pour y débusquer la poésie de l'ordinaire, le jeu des ombres sur le béton, et cette lumière qui transforme une ruelle banale en un théâtre de néons ou de brume.
      </p>

      <blockquote class="pull-quote reveal-on-scroll">
        <span class="mark" aria-hidden="true">«</span>
        La poésie de l'ordinaire, le jeu des ombres sur le béton.
        <span class="mark" aria-hidden="true">»</span>
      </blockquote>

      <p>
        Chaque «&nbsp;Roll&nbsp;» présenté ici est le fragment d'une histoire vécue, une immersion sensorielle où la couleur et le silence se répondent. Bienvenue dans mon journal.
      </p>
    </article>

    <footer class="colophon reveal-on-scroll">
      <div class="signature">— <em>Wanderer</em></div>
      <nav class="meta" aria-label="Liens de pied de page">
        <span class="dateline-meta">Paris · Carnet d'errance · MMXXVI</span>
        <a href="https://instagram.com/stillsource" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="mailto:hello@example.com">Écrire</a>
        <a href="/" class="home">Retour au recueil <span aria-hidden="true">→</span></a>
      </nav>
    </footer>
  </main>

  <style>
    .about-editorial {
      max-width: 68rem;
      margin: 0 auto;
      padding: clamp(6rem, 12vw, 12rem) clamp(1.5rem, 5vw, 4rem) clamp(6rem, 12vw, 14rem);
      color: var(--text-main);
      position: relative;
    }

    /* ── Masthead ───────────────────────────────────────────── */

    .masthead {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: baseline;
      gap: 2rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid currentColor;
      border-bottom-color: color-mix(in srgb, var(--text-muted) 45%, transparent);
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.32em;
      color: var(--text-muted);
    }
    .masthead .issue {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      text-transform: none;
      letter-spacing: 0;
      font-size: 1.15rem;
      color: var(--accent);
    }
    .masthead .edition {
      justify-self: center;
      text-align: center;
    }
    .masthead .dateline {
      justify-self: end;
    }

    /* ── Hero ───────────────────────────────────────────────── */

    .hero {
      margin: clamp(4rem, 10vw, 8rem) 0 clamp(3rem, 7vw, 5rem);
      max-width: 52rem;
    }
    .kicker {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.45em;
      color: var(--accent);
      margin: 0 0 1.5rem;
      padding-left: 1.5rem;
      position: relative;
    }
    .kicker::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      width: 1rem;
      height: 1px;
      background: var(--accent);
      transform: translateY(-50%);
    }

    .title {
      font-family: 'Bodoni Moda', serif;
      font-weight: 400;
      font-size: clamp(3.25rem, 9vw, 7.5rem);
      line-height: 0.92;
      letter-spacing: -0.025em;
      margin: 0;
      color: var(--text-main);
    }
    .title em {
      font-style: italic;
      display: inline-block;
      margin-right: 0.1em;
    }
    .title .roman {
      font-style: normal;
      font-weight: 500;
    }

    .standfirst {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-weight: 400;
      font-size: clamp(1.15rem, 2.2vw, 1.6rem);
      line-height: 1.45;
      max-width: 40rem;
      margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
      color: var(--text-muted);
    }

    /* ── Body ───────────────────────────────────────────────── */

    .body {
      max-width: 36rem;
      margin-left: clamp(0rem, 6vw, 4rem);
      font-family: 'Inter', sans-serif;
      font-size: 1.0625rem;
      line-height: 1.85;
      color: var(--text-main);
    }
    .body > * + * { margin-top: 2rem; }
    .body p { margin: 0; }

    /* ── Byline portrait (graceful placeholder until /portrait.jpg exists) */

    .byline-portrait {
      float: right;
      width: clamp(150px, 26vw, 220px);
      aspect-ratio: 3 / 4;
      margin: 0.5rem 0 1.5rem clamp(1.5rem, 3vw, 2.5rem);
      position: relative;
      isolation: isolate;
      overflow: hidden;
    }
    .byline-portrait .portrait-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.08);
      display: block;
    }
    .byline-portrait .portrait-fallback {
      position: absolute;
      inset: 0;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      border: 1px solid color-mix(in srgb, var(--text-muted) 45%, transparent);
      background:
        repeating-linear-gradient(
          135deg,
          transparent 0 14px,
          color-mix(in srgb, var(--text-muted) 12%, transparent) 14px 15px
        );
      color: var(--text-muted);
    }
    .byline-portrait.no-image .portrait-fallback {
      display: flex;
    }
    .portrait-monogram {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-size: clamp(2.8rem, 6vw, 4rem);
      line-height: 1;
      color: var(--accent);
    }
    .portrait-hint {
      font-family: 'Inter', sans-serif;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.4em;
      color: var(--text-muted);
    }

    @media (max-width: 640px) {
      .byline-portrait {
        float: none;
        width: min(70%, 240px);
        margin: 0 auto 2rem;
      }
    }

    .drop-cap::first-letter {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-weight: 600;
      font-size: 5.5rem;
      float: left;
      line-height: 0.82;
      margin: 0.35rem 0.8rem 0 0;
      color: var(--accent);
    }

    /* ── Pull quote ─────────────────────────────────────────── */

    .pull-quote {
      position: relative;
      margin: clamp(2.5rem, 6vw, 4.5rem) calc(var(--quote-indent, -3vw)) clamp(2.5rem, 6vw, 4.5rem);
      padding: clamp(2rem, 4vw, 3rem) 0;
      border-top: 1px solid color-mix(in srgb, var(--text-muted) 35%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--text-muted) 35%, transparent);
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-weight: 400;
      font-size: clamp(1.5rem, 3.3vw, 2.35rem);
      line-height: 1.3;
      text-align: center;
      color: var(--text-main);
    }
    .pull-quote .mark {
      font-size: 1.2em;
      line-height: 0;
      color: var(--accent);
      opacity: 0.65;
      vertical-align: -0.05em;
      margin: 0 0.15em;
    }

    /* ── Colophon ───────────────────────────────────────────── */

    .colophon {
      margin-top: clamp(4rem, 10vw, 7rem);
      padding-top: 1.25rem;
      border-top: 1px solid color-mix(in srgb, var(--text-muted) 45%, transparent);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2rem 3rem;
      align-items: baseline;
    }
    .signature {
      font-family: 'Bodoni Moda', serif;
      font-size: 1.6rem;
      color: var(--accent);
    }
    .signature em {
      font-style: italic;
    }
    .meta {
      justify-self: end;
      display: flex;
      flex-wrap: wrap;
      gap: 1.75rem;
      align-items: center;
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: var(--text-muted);
    }
    .meta a {
      color: var(--text-muted);
      text-decoration: none;
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
      transition: color 0.3s ease, border-color 0.3s ease;
    }
    .meta a:hover,
    .meta a:focus-visible {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
    .meta .home {
      color: var(--text-main);
    }
    .meta .dateline-meta {
      font-style: normal;
    }

    /* ── Reveal cascade ─────────────────────────────────────── */

    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 0.65s cubic-bezier(0.2, 0.8, 0.2, 1),
        transform 0.65s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .stagger-1 { transition-delay: 60ms; }
    .stagger-2 { transition-delay: 140ms; }
    .stagger-3 { transition-delay: 220ms; }
    .stagger-4 { transition-delay: 300ms; }

    @media (prefers-reduced-motion: reduce) {
      .reveal-on-scroll {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }

    /* ── Responsive ─────────────────────────────────────────── */

    @media (max-width: 768px) {
      .masthead {
        grid-template-columns: 1fr;
        gap: 0.5rem;
        text-align: center;
      }
      .masthead .edition,
      .masthead .dateline {
        justify-self: center;
      }
      .body {
        margin-left: 0;
      }
      .pull-quote {
        margin-inline: 0;
      }
      .colophon {
        grid-template-columns: 1fr;
        text-align: center;
      }
      .meta {
        justify-self: center;
        justify-content: center;
      }
    }
  </style>

  <script>
    import { applyThemeColors } from '../scripts/utils/colors';
    import { initScrollReveal } from '../scripts/utils/scroll';

    function setupAboutPage() {
      // Neutral aura palette — the about page has no roll palette to inherit.
      applyThemeColors(['#1a1a1a', '#0a0a0a', '#151515', '#050505', '#101010'], true);
      initScrollReveal();
    }

    document.addEventListener('astro:page-load', setupAboutPage);
  </script>
</Layout>
