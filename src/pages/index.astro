---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SplashScreen from '../components/SplashScreen.astro';
import Navbar from '../components/Navbar.astro';
import { getTagCategory } from '../data/categories';
import { neutralTextForPalette } from '../data/poemColor';

const allRolls = await getCollection('rolls');
const sortedRolls = allRolls.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Extract unique tags
const allTags = [...new Set(sortedRolls.flatMap(roll => roll.data.tags || []))].sort();

// Group actual tags present in rolls by category
const groupedTags = allTags.reduce((acc, tag) => {
  const cat = getTagCategory(tag);
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(tag);
  return acc;
}, {} as Record<string, string[]>);
---

<Layout
  title="Hors-Champ — Photographies sans mise en scène"
  description="Hors-Champ — Photographies sans mise en scène, carnets d'errance."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Hors-Champ",
    "url": Astro.site?.href ?? Astro.url.origin,
    "description": "Hors-Champ — Photographies sans mise en scène, carnets d'errance.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${Astro.site?.href ?? Astro.url.origin}?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  }}
>
  <SplashScreen />
  <Navbar mode="index" />

  <main class="index-container">
    <header class="index-header">
      <h2>Recueil</h2>
      <p>Instants suspendus, fragments de rues et poésie de l'ordinaire.</p>
    </header>

    <div class="filter-disclosure" id="filter-disclosure">
      <button
        id="filter-disclosure-toggle"
        class="filter-disclosure-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="filter-section"
      >
        <span class="filter-disclosure-rule" aria-hidden="true"></span>
        <span class="filter-disclosure-label">Explorer par thème</span>
        <span class="filter-disclosure-chevron" aria-hidden="true">↓</span>
      </button>
    </div>

    <div class="filter-section" id="filter-section" aria-hidden="true">
      <div class="filter-group">
        <span class="group-label">Vue</span>
        <div class="group-btns">
          <button class="filter-btn active" data-filter="all" aria-pressed="true">Tout</button>
        </div>
      </div>

      {Object.entries(groupedTags).map(([category, tags]) => (
        <div class="filter-group">
          <span class="group-label">{category}</span>
          <div class="group-btns">
            {tags.map(tag => (
              <button class="filter-btn" data-filter={tag} aria-pressed="false">{tag}</button>
            ))}
          </div>
        </div>
      ))}
    </div>
    <span id="filter-status" class="sr-only" aria-live="polite" aria-atomic="true"></span>

    <div id="roll-video-bg" aria-hidden="true"></div>

    <ul class="roll-list" id="roll-list">
      {sortedRolls.map((roll, index) => {
        const baseColor = roll.data.palette?.[0] ?? roll.data.dominantColor;
        const poem = neutralTextForPalette(baseColor);
        return (
          <li
            class="roll-item"
            style={`animation-delay: ${0.8 + index * 0.1}s; --poem-l: ${poem.light}; --poem-d: ${poem.dark};`}
            data-tags={JSON.stringify(roll.data.tags || [])}
          >
            <a
              href={`/roll/${roll.id}`}
              class="roll-link color-hover-trigger"
              data-palette={JSON.stringify(roll.data.palette || [])}
              data-color={roll.data.palette ? roll.data.palette[0] : "#050505"}
              data-video={roll.data.videoUrl ?? ''}
            >
              <span class="date">{roll.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}</span>
              <span class="title">{roll.data.title}</span>
              {roll.data.poem && <span class="excerpt">{roll.data.poem.substring(0, 100)}...</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </main>

  <style is:global>
    /* ----- NARRATIVE INDEX ----- */
    .index-container {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .index-header {
      margin-bottom: 6rem;
      opacity: 0;
      transform: translateY(20px);
    }

    .index-header.is-visible {
      animation: reveal 1s ease forwards;
    }

    .index-header h2 {
      font-family: 'Bodoni Moda', serif;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.4em;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .index-header p {
      font-family: 'Bodoni Moda', serif;
      font-size: clamp(1.5rem, 5vw, 2.5rem);
      font-style: italic;
      line-height: 1.2;
      max-width: 600px;
    }

    /* ----- ORGANIZED FILTERING ----- */
    .filter-disclosure {
      margin-bottom: 4rem;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 1s ease, transform 1s ease;
    }
    .filter-disclosure.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .filter-disclosure-toggle {
      width: 100%;
      background: none;
      border: none;
      padding: 0.6rem 0;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.34em;
      color: var(--text-muted);
      transition: color 0.3s ease;
    }
    .filter-disclosure-toggle:hover,
    .filter-disclosure-toggle:focus-visible {
      color: var(--accent);
    }
    .filter-disclosure-rule {
      flex: 1;
      height: 1px;
      background: color-mix(in srgb, var(--text-muted) 45%, transparent);
      transition: background 0.3s ease;
    }
    .filter-disclosure-toggle:hover .filter-disclosure-rule,
    .filter-disclosure-toggle:focus-visible .filter-disclosure-rule {
      background: color-mix(in srgb, var(--accent) 70%, transparent);
    }
    .filter-disclosure-chevron {
      display: inline-block;
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .filter-disclosure-toggle[aria-expanded="true"] .filter-disclosure-chevron {
      transform: rotate(180deg);
    }

    .filter-section {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 2.5rem;
      margin-bottom: 0;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transform: translateY(-6px);
      transition:
        max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.4s ease,
        transform 0.45s cubic-bezier(0.4, 0, 0.2, 1),
        margin-bottom 0.4s ease;
    }

    @media (max-width: 640px) {
      .filter-section {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem 1.5rem;
      }
    }

    .filter-section.is-open {
      max-height: 120rem;
      opacity: 1;
      transform: translateY(0);
      margin-bottom: 6rem;
    }

    @media (prefers-reduced-motion: reduce) {
      .filter-section {
        transition: none;
      }
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .group-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: var(--text-muted);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding-bottom: 0.5rem;
    }

    .group-btns {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .filter-btn {
      background: none;
      border: none;
      color: var(--text-muted);
      font-family: 'Bodoni Moda', serif;
      font-size: 1.1rem;
      font-style: italic;
      cursor: pointer;
      padding: 0.2rem 0;
      transition: all 0.3s ease;
      text-align: left;
    }

    .filter-btn:hover {
      color: var(--text-main);
      transform: translateX(5px);
    }

    .filter-btn.active {
      color: var(--accent);
      padding-left: 1rem;
      border-left: 1px solid var(--accent);
    }

    #roll-video-bg {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
    }
    #roll-video-bg video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.8s ease;
    }
    #roll-video-bg video.is-visible {
      opacity: 0.15;
    }

    .roll-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .roll-item {
      margin-bottom: 3rem;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .roll-item.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .roll-item.hidden {
      display: none;
    }

    .roll-link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .roll-link .date {
      font-family: 'Inter', sans-serif;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .roll-link .title {
      font-family: 'Bodoni Moda', serif;
      font-size: clamp(2rem, 8vw, 4rem);
      font-style: italic;
      transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      display: inline-block;
    }

    .roll-link:hover .title {
      transform: translateX(20px);
      color: var(--accent);
    }

    .roll-link .excerpt {
      display: block;
      max-width: 400px;
      font-size: 0.9rem;
      color: var(--poem-d, var(--text-poem));
      margin-top: 0.5rem;
      line-height: 1.6;
      opacity: 0;
      transform: translateX(20px);
      transition: all 0.4s ease;
    }

    :root[data-theme="light"] .roll-link .excerpt {
      color: var(--poem-l, var(--text-poem));
    }

    .roll-link:hover .excerpt {
      opacity: 1;
      transform: translateX(30px);
    }

    @keyframes reveal {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    import { applyThemeColors } from '../scripts/utils/colors';

    function setupIndexColorHover() {
      const list = document.getElementById('roll-list');
      const videoBg = document.getElementById('roll-video-bg');
      if (!list) return;

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let currentVideo: HTMLVideoElement | null = null;
      let fadeOutTimer: ReturnType<typeof setTimeout> | null = null;

      const showVideo = (url: string) => {
        if (reducedMotion || !url || !videoBg) return;

        if (currentVideo && currentVideo.dataset.src === url) {
          currentVideo.classList.add('is-visible');
          return;
        }

        // Reuse or create the video element
        if (!currentVideo) {
          currentVideo = document.createElement('video');
          currentVideo.muted = true;
          currentVideo.loop = true;
          currentVideo.playsInline = true;
          currentVideo.setAttribute('aria-hidden', 'true');
          videoBg.appendChild(currentVideo);
        }

        currentVideo.dataset.src = url;
        currentVideo.src = url;
        currentVideo.play().catch(() => {});
        currentVideo.classList.add('is-visible');
      };

      const hideVideo = () => {
        if (!currentVideo) return;
        currentVideo.classList.remove('is-visible');
        fadeOutTimer = setTimeout(() => {
          currentVideo?.pause();
        }, 800);
      };

      list.addEventListener('mouseenter', (e) => {
        const trigger = (e.target as HTMLElement).closest('.color-hover-trigger') as HTMLElement;
        if (trigger) {
          if (fadeOutTimer) { clearTimeout(fadeOutTimer); fadeOutTimer = null; }
          const paletteStr = trigger.dataset.palette;
          if (paletteStr) applyThemeColors(JSON.parse(paletteStr), true);
          if (trigger.dataset.video) showVideo(trigger.dataset.video);
        }
      }, true);

      list.addEventListener('mouseleave', (e) => {
        const trigger = (e.target as HTMLElement).closest('.color-hover-trigger') as HTMLElement;
        if (trigger) {
          applyThemeColors([], false);
          hideVideo();
        }
      }, true);
    }

    // Reveal timeout IDs — cancellable if a filter is triggered before the end
    let revealTimeoutIds: ReturnType<typeof setTimeout>[] = [];

    function setupIndexFilters() {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const rollItems = document.querySelectorAll('.roll-item');
      const filterStatus = document.getElementById('filter-status');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.filter;
          if (!filter) return;

          // Cancel pending reveal timeouts to avoid a race condition
          revealTimeoutIds.forEach(id => clearTimeout(id));
          revealTimeoutIds = [];

          filterBtns.forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');

          let visibleCount = 0;
          rollItems.forEach(item => {
            const tags = JSON.parse((item as HTMLElement).dataset.tags || '[]');
            if (filter === 'all' || tags.includes(filter)) {
              item.classList.remove('hidden');
              item.classList.add('is-visible');
              visibleCount++;
            } else {
              item.classList.remove('is-visible');
              item.classList.add('hidden');
            }
          });

          if (filterStatus) {
            filterStatus.textContent = filter === 'all'
              ? `${visibleCount} rolls affichés`
              : `${visibleCount} roll${visibleCount > 1 ? 's' : ''} tagué${visibleCount > 1 ? 's' : ''} "${filter}"`;
          }
        });
      });
    }

    function setupReveal() {
      const header = document.querySelector('.index-header');
      const disclosure = document.querySelector('.filter-disclosure');
      const items = document.querySelectorAll('.roll-item');

      revealTimeoutIds = [];

      const revealAll = () => {
        if (!header) return;
        header.classList.add('is-visible');
        setTimeout(() => disclosure?.classList.add('is-visible'), 200);
        items.forEach((item, i) => {
          const id = setTimeout(() => item.classList.add('is-visible'), 400 + (i * 100));
          revealTimeoutIds.push(id);
        });
      };

      if (sessionStorage.getItem('splashSeen')) {
        revealAll();
      } else {
        window.addEventListener('splashFinished', revealAll, { once: true });
      }
    }

    function setupFilterDisclosure() {
      const toggle = document.getElementById('filter-disclosure-toggle');
      const panel = document.getElementById('filter-section');
      if (!toggle || !panel) return;

      const setOpen = (open: boolean) => {
        panel.classList.toggle('is-open', open);
        toggle.setAttribute('aria-expanded', String(open));
        panel.setAttribute('aria-hidden', String(!open));
      };

      // Idempotent call on every navigation keeps ARIA honest.
      const isOpen = panel.classList.contains('is-open');
      setOpen(isOpen);

      const w = window as Window & { __filter_disclosure_initialized?: boolean };
      if (w.__filter_disclosure_initialized) return;
      w.__filter_disclosure_initialized = true;

      toggle.addEventListener('click', () => {
        setOpen(!panel.classList.contains('is-open'));
      });

      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        if (!panel.classList.contains('is-open')) return;
        setOpen(false);
        (toggle as HTMLElement).focus();
      });
    }

    document.addEventListener('astro:page-load', () => {
      setupIndexColorHover();
      setupIndexFilters();
      setupFilterDisclosure();
      setupReveal();
    });
  </script>
</Layout>
