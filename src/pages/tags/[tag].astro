---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Roll from '../../components/Roll.astro';
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths() {
  const allRolls = await getCollection('rolls');
  const uniqueTags = [...new Set(allRolls.map((roll) => roll.data.tags || []).flat())];

  return uniqueTags.map((tag) => {
    const filteredRolls = allRolls.filter((roll) =>
      roll.data.tags?.includes(tag)
    );
    return {
      params: { tag },
      props: { rolls: filteredRolls },
    };
  });
}

const { tag } = Astro.params;
const { rolls } = Astro.props;
---

<Layout title={`Tag: ${tag} - Wanderer's Journal`}>
  <Navbar mode="roll" />

  <main>
    <div class="tag-hero">
      <span class="tag-label">Exploration par tag</span>
      <h1 class="tag-title">{tag}</h1>
    </div>

    {rolls.map(roll => (
      <Roll title={roll.data.title} poem={roll.data.poem} images={roll.data.images} dominantColor={roll.data.dominantColor} />
    ))}
  </main>

  <style is:global>
    .tag-hero {
      padding: 10rem 2rem 5rem;
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .tag-label {
      font-family: 'Inter', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-size: 0.7rem;
      color: var(--text-muted);
      display: block;
      margin-bottom: 1rem;
    }

    .tag-title {
      font-family: 'Bodoni Moda', serif;
      font-size: clamp(3rem, 12vw, 6rem);
      font-style: italic;
      color: var(--text-main);
      margin: 0;
    }

    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), 
                  transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
      will-change: opacity, transform;
    }

    .reveal-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    import { initScrollReveal } from '../../scripts/utils/scroll';

    document.addEventListener('astro:page-load', () => initScrollReveal());
  </script>
</Layout>
