{
  "name": "marvelous-journal-of-a-wanderer",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "sync": "KDRIVE_OUT_DIR=\"$PWD/src/content/rolls/synced\" KDRIVE_INDEX_FILE=\"$PWD/public/search-index.json\" go -C src/scripts/go/kdrive-sync run ./cmd",
    "build": "astro build",
    "build:full": "npm run sync && astro build",
    "preview": "astro preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@fontsource/bodoni-moda": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@playwright/test": "^1.59.1",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "vitest": "^4.1.4"
  }
}
